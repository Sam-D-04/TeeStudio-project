PORT=5000
NODE_ENV=development
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=teestudio
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# Optional: mysql2 also supports using a single connection string.
# DATABASE_URL="mysql://root:password@localhost:3306/teestudio"

# Authentication. Use long, random and different secrets outside local development.
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Gmail account used to send system emails. EMAIL_PASS must be a 16-character
# Google App Password, not the Gmail account password.
EMAIL_USER=email_cua_ban@gmail.com
EMAIL_PASS=mat_khau_ung_dung_16_ky_tu

# VNPAY sandbox/production configuration.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
# IP công khai của backend dùng khi gọi QueryDR (production).
VNPAY_API_IP=127.0.0.1
VNPAY_RETURN_URL=http://localhost:3000/thanh-toan-thanh-cong
# Cấu hình URL này trong merchant VNPAY; môi trường thật phải là URL HTTPS công khai.
VNPAY_IPN_URL=http://localhost:5000/api/payments/vnpay/ipn

# MoMo sandbox configuration. Lấy thông tin merchant sandbox của bạn tại MoMo Business.
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_PAYMENT_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_QUERY_URL=https://test-payment.momo.vn/v2/gateway/api/query
MOMO_REQUEST_TYPE=payWithMethod
MOMO_PARTNER_NAME=TeeStudio
MOMO_STORE_ID=TeeStudio
MOMO_REDIRECT_URL=http://localhost:3000/thanh-toan-thanh-cong
# Khi deploy, URL IPN phải là HTTPS công khai để MoMo gọi được server-to-server.
MOMO_IPN_URL=http://localhost:5000/api/payments/momo/ipn
